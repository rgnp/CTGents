# ── DeepSeek API（必需）──
DEEPSEEK_API_KEY=your_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com

# ── 双模型配置（可选，有默认值）──
# Flash: 快速/省钱，适合日常任务
MODEL_FLASH=deepseek-v4-flash
FLASH_MAX_TOKENS=8192

# Pro: 强推理，适合复杂代码任务
MODEL_PRO=deepseek-v4-pro
PRO_MAX_TOKENS=8192

# ── Tavily 搜索（必需）──
TAVILY_API_KEY=your_tavily_api_key_here
